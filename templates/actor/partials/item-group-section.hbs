<section
  class='item-group {{#if group.isSimple}}item-group--simple{{/if}} {{#if group.isCardTable}}item-group--card-table{{/if}}'
  data-item-group='{{group.key}}'
>
  <div class='item-group__columns'>
    <span class='item-group__column-title'>
      {{#if group.icon}}<i class='{{group.icon}}'></i>{{/if}}
      <span>{{group.label}}</span>
      {{#if group.capacity}}
        <span class='item-group__capacity'>{{group.capacity.value}} / {{group.capacity.max}}</span>
      {{/if}}
      {{#if group.isCardTable}}
        <button
          type='button'
          class='item-create item-group__create item-group__create--inline'
          data-type='{{group.type}}'
          data-group-key='{{group.key}}'
          title='{{group.createLabel}}'
        >
          <i class='fa-solid fa-plus'></i>
          <span class='sr-only'>{{group.createLabel}}</span>
        </button>
      {{/if}}
    </span>
    {{#unless group.isSimple}}
      {{#unless group.isCardTable}}
      <span>{{localize 'MY_RPG.ItemTableColumns.Check'}}</span>
      <span>{{localize 'MY_RPG.ItemTableColumns.Activation'}}</span>
      {{/unless}}
    {{/unless}}
    {{#unless group.isCardTable}}
    <span class='item-group__column-actions'>
      <button
        type='button'
        class='item-create item-control item-group__create'
        data-type='{{group.type}}'
        data-group-key='{{group.key}}'
        title='{{group.createLabel}}'
      >
        <i class='fa-solid fa-plus'></i>
        <span class='sr-only'>{{group.createLabel}}</span>
      </button>
    </span>
    {{/unless}}
  </div>
  {{#if group.items.length}}
    <ol class='item-list'>
      {{#each group.items as |item|}}
        <li
          class='item-row {{#if item.equipped}}item-row--equipped{{/if}} {{#if item.cooldownUsed}}item-row--cooldown-used{{/if}} {{#if item.isExpanded}}item-row--expanded{{/if}}'
          data-item-id='{{item.id}}'
          data-group-key='{{item.groupKey}}'
        >
          <div
            class='item-row__summary-grid'
            data-item-summary-toggle='true'
            role='button'
            tabindex='0'
            aria-expanded='{{#if item.isExpanded}}true{{else}}false{{/if}}'
          >
            <div class='item-row__name'>
              <img src='{{item.img}}' alt='' />
              <div class='item-row__identity'>
                <div class='item-row__title-line'>
                  <span class='item-row__label'>{{item.name}}</span>
                  <span class='item-row__toggle' aria-hidden='true'>
                    <i class='fa-solid fa-chevron-down item-row__toggle-icon'></i>
                  </span>
                </div>
                {{#if item.hasCardTags}}
                  <ul class='item-row__card-tags' aria-label='{{item.cardTagsLabel}}'>
                    {{#each item.cardTags as |tag|}}
                      <li class='item-row__card-tag {{tag.className}}' title='{{tag.title}}'>
                        {{#if tag.isCheck}}
                          {{#if tag.hasSkill}}
                            <span class='item-row__card-check-skill'>{{tag.skillLabel}}</span>
                            {{#if tag.hasCheck}}
                              <span
                                class='item-row__card-check-rank {{tag.rankClass}}'
                              >{{tag.rankRoman}}</span>
                              <strong class='item-row__card-check-bonus'>{{tag.bonusLabel}}</strong>
                            {{else}}
                              <span class='item-row__card-check-empty'>{{tag.emptyLabel}}</span>
                            {{/if}}
                          {{else}}
                            <span class='item-row__card-check-empty'>{{tag.emptyLabel}}</span>
                          {{/if}}
                        {{else}}
                          {{tag.label}}
                        {{/if}}
                      </li>
                    {{/each}}
                  </ul>
                {{/if}}
              </div>
            </div>
            {{#unless ../group.isSimple}}
              <div class='item-row__check'>
                {{#if item.checkSummary.hasCheck}}
                  <span class='item-row__check-skill'>{{item.checkSummary.skillLabel}}</span>
                  <span
                    class='item-row__check-rank {{item.checkSummary.rankClass}}'
                  >{{item.checkSummary.rankRoman}}</span>
                  <span class='item-row__check-bonus'>+{{item.checkSummary.bonus}}</span>
                {{else}}
                  <span class='item-row__check-empty'>—</span>
                {{/if}}
              </div>
              <div class='item-row__activation'>
                <span class='item-row__activation-cost' title='{{item.activationSummary}}'>
                  {{item.activationShortSummary}}
                </span>
              </div>
            {{/unless}}
            <div class='item-row__actions' data-item-id='{{item.id}}' data-group-key='{{item.groupKey}}'>
              {{#if item.showQuantity}}
                <div class='item-quantity-control' aria-label='{{@root.itemControls.quantity}}'>
                  <button
                    type='button'
                    class='item-quantity-step'
                    data-step='-1'
                    title='{{@root.itemControls.quantityDecrease}}'
                  >
                    <i class='fa-solid fa-minus'></i>
                    <span class='sr-only'>{{@root.itemControls.quantityDecrease}}</span>
                  </button>
                  <span class='item-quantity-value'>{{item.quantity}}</span>
                  <button
                    type='button'
                    class='item-quantity-step'
                    data-step='1'
                    title='{{@root.itemControls.quantityIncrease}}'
                  >
                    <i class='fa-solid fa-plus'></i>
                    <span class='sr-only'>{{@root.itemControls.quantityIncrease}}</span>
                  </button>
                </div>
              {{/if}}
              {{#if item.showEquip}}
                <label class='item-equip-toggle' title='{{@root.itemControls.equip}}'>
                  <input
                    type='checkbox'
                    class='item-equip-checkbox'
                    {{#if item.equipped}}checked{{/if}}
                    aria-label='{{@root.itemControls.equipAria}}'
                  />
                </label>
              {{/if}}
              {{#if item.hasActivationControl}}
                <button
                  type='button'
                  class='item-activate item-control {{#if item.hasCooldown}}item-activate--trackable{{/if}} {{#if item.cooldownUsed}}item-activate--used{{/if}}'
                  data-item-id='{{item.id}}'
                  data-group-key='{{item.groupKey}}'
                  data-default-icon='{{item.activationControlDefaultIcon}}'
                  data-default-title='{{item.activationControlDefaultTitle}}'
                  title='{{item.activationControlTitle}}'
                  aria-pressed='{{#if item.cooldownUsed}}true{{else}}false{{/if}}'
                >
                  <i class='{{item.activationControlIcon}}'></i>
                  <span class='sr-only'>{{item.activationControlTitle}}</span>
                </button>
              {{/if}}
              {{#if item.hasChatControl}}
                <button
                  type='button'
                  class='item-chat item-control'
                  data-item-id='{{item.id}}'
                  data-group-key='{{item.groupKey}}'
                  title='{{@root.itemControls.chat}}'
                >
                  <i class='fa-solid fa-message'></i>
                  <span class='sr-only'>{{@root.itemControls.chat}}</span>
                </button>
              {{/if}}
              <button
                type='button'
                class='item-edit item-control'
                data-item-id='{{item.id}}'
                data-group-key='{{item.groupKey}}'
                title='{{@root.itemControls.edit}}'
              >
                <i class='fa-solid fa-pen'></i>
                <span class='sr-only'>{{@root.itemControls.edit}}</span>
              </button>
              <button
                type='button'
                class='item-delete item-control'
                data-item-id='{{item.id}}'
                data-group-key='{{item.groupKey}}'
                title='{{@root.itemControls.delete}}'
              >
                <i class='fa-solid fa-trash'></i>
                <span class='sr-only'>{{@root.itemControls.delete}}</span>
              </button>
            </div>
          </div>
          {{#if item.hasDetails}}
            <div class='item-row__detail' {{#unless item.isExpanded}}hidden{{/unless}}>
              {{#if item.isCardTableItem}}
                {{#if item.detailEffect}}
                  <div class='item-row__detail-effect item-row__detail-effect--card-table'>
                    {{{item.detailEffect}}}
                  </div>
                {{/if}}
                {{#if item.detailRows.length}}
                  <div class='item-row__detail-grid item-row__detail-grid--card-table'>
                    {{#each item.detailRows as |row|}}
                      <div class='item-row__detail-line'>
                        {{#each row as |entry|}}
                          <span class='item-row__detail-entry'>
                            <strong>{{entry.label}}</strong>
                            {{entry.value}}
                          </span>
                        {{/each}}
                      </div>
                    {{/each}}
                  </div>
                {{/if}}
              {{else}}
              {{#if item.detailRows.length}}
                <div class='item-row__detail-grid'>
                  {{#each item.detailRows as |row|}}
                    <div class='item-row__detail-line'>
                      {{#each row as |entry|}}
                        <span class='item-row__detail-entry'>
                          <strong>{{entry.label}}</strong>
                          {{entry.value}}
                        </span>
                      {{/each}}
                    </div>
                  {{/each}}
                </div>
              {{/if}}
              {{#if item.detailEffect}}
                <div class='item-row__detail-effect'>
                  {{{item.detailEffect}}}
                </div>
              {{/if}}
              {{/if}}
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ol>
  {{else}}
    <p class='item-group__empty'>{{group.empty}}</p>
  {{/if}}
</section>
