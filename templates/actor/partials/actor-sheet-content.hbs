<form class='{{cssClass}} {{actor.type}} flexcol' autocomplete='off'>
  <div class='andromeda-sheet-shell'>
    <section class='andromeda-identity'>
      <div class='andromeda-portrait-card'>
        <img class='profile-img' src='{{actor.img}}' data-edit='img' title='{{actor.name}}' />
        <div class='andromeda-identity-fields'>
          <label class='andromeda-field andromeda-field--name'>
            <span>{{localize 'MY_RPG.KeyInfo.Name'}}</span>
            <input type='text' name='name' value='{{actor.name}}' />
          </label>

          <div class='andromeda-meta-row'>
            {{#if isPlayerCharacter}}
              <label class='andromeda-field'>
                <span>{{localize 'MY_RPG.KeyInfo.Calling'}}</span>
                <input type='text' name='system.calling' value='{{system.calling}}' />
              </label>
            {{/if}}

            <label class='andromeda-field andromeda-field--compact'>
              <span>{{localize 'MY_RPG.KeyInfo.CurrentRank'}}</span>
              <input
                type='number'
                name='system.currentRank'
                value='{{system.currentRank}}'
                step='1'
                min='0'
                inputmode='numeric'
              />
            </label>

            {{#if isPlayerCharacter}}
              <label class='andromeda-field andromeda-field--compact'>
                <span>{{localize 'MY_RPG.KeyInfo.MomentOfGlory'}}</span>
                <input
                  type='number'
                  name='system.momentOfGlory'
                  value='{{system.momentOfGlory}}'
                  step='1'
                  inputmode='numeric'
                />
              </label>
            {{/if}}

            {{#if isGmCharacter}}
              <label class='andromeda-field andromeda-field--compact'>
                <span>{{localize 'MY_RPG.KeyInfo.SharedMomentOfGlory'}}</span>
                <input
                  type='number'
                  class='shared-hero-pool-input'
                  value='{{sharedHeroPool}}'
                  step='1'
                  min='0'
                  inputmode='numeric'
                />
              </label>
            {{/if}}
          </div>

          <div class='andromeda-rank-legend' aria-label='{{localize "MY_RPG.RankNumeric.Title"}}'>
            <span class='rank1'>{{rankLabel 1}}</span>
            <span class='rank2'>{{rankLabel 2}}</span>
            <span class='rank3'>{{rankLabel 3}}</span>
            <span class='rank4'>{{rankLabel 4}}</span>
          </div>
        </div>
      </div>

      <div class='andromeda-identity-metrics'>
        <label class='andromeda-metric andromeda-metric--speed'>
          <span>{{localize 'MY_RPG.Speed.Label'}}</span>
          <input
            type='number'
            name='system.speed.value'
            value='{{system.speed.value}}'
            step='1'
            inputmode='numeric'
            readonly
            tabindex='-1'
          />
          <small>{{localize 'MY_RPG.SheetHints.SpeedFormula'}}</small>
        </label>

        {{#if isPlayerCharacter}}
          <label class='andromeda-metric andromeda-metric--progress'>
            <span>{{localize 'MY_RPG.SheetHints.Progress'}}</span>
            <input
              type='number'
              name='system.progressPoints'
              value='{{system.progressPoints}}'
              step='1'
              inputmode='numeric'
            />
            <small>
              {{localize 'MY_RPG.SheetHints.AvailableTotal'}}
              <strong data-field='system.advancement.totalSpent'>{{system.advancement.totalSpent}}</strong>
            </small>
          </label>
        {{/if}}
      </div>

      <div class='andromeda-resource-stack'>
        <section class='andromeda-track-card health-resource health-resource--stress'>
          <header>
            <span>{{localize 'MY_RPG.Stress.Label'}}</span>
            <strong>{{system.stress.value}} / {{system.stress.max}}</strong>
          </header>
          <div class='stress-track health-track' data-total='{{system.stress.max}}'>
            {{#each system.stressTrack as |cell|}}
              <button
                type='button'
                class='stress-cell health-cell {{cell.stateClass}}'
                data-index='{{cell.index}}'
                aria-label='{{cell.ariaLabel}}'
                aria-pressed='{{cell.ariaPressed}}'
              ></button>
            {{/each}}
          </div>
        </section>

        <section class='andromeda-track-card health-resource health-resource--shield'>
          <header>
            <span>{{localize 'MY_RPG.ForceShield.Label'}}</span>
            <strong>{{system.forceShield.value}} / {{system.forceShield.max}}</strong>
          </header>
          <div class='force-shield-track health-track' data-total='{{system.forceShield.max}}'>
            {{#each system.forceShieldTrack as |cell|}}
              <button
                type='button'
                class='force-shield-cell health-cell {{cell.stateClass}}'
                data-index='{{cell.index}}'
                aria-label='{{cell.ariaLabel}}'
                aria-pressed='{{cell.ariaPressed}}'
              ></button>
            {{/each}}
          </div>
        </section>
      </div>
    </section>

    <nav class='andromeda-sheet-tabs tabs' data-group='primary'>
      <a class='andromeda-tab item' data-tab='features'>
        {{localize 'MY_RPG.SheetLabels.Features'}}
      </a>
      {{#each itemTabs as |tab|}}
        <a class='andromeda-tab item' data-tab='{{tab.key}}'>
          {{tab.label}}
        </a>
      {{/each}}
      {{#if isPlayerCharacter}}
        <a class='andromeda-tab item' data-tab='personality'>
          {{localize 'MY_RPG.SheetLabels.Personality'}}
        </a>
      {{/if}}
    </nav>

    <div class='sheet-scrollable'>
      <section class='sheet-body andromeda-sheet-body'>
        <div
          class='tab features features-tab andromeda-main-tab'
          data-group='primary'
          data-tab='features'
        >
          <section class='andromeda-overview-grid'>
            <div class='andromeda-overview-main'>
              <section class='andromeda-panel'>
                <header class='andromeda-panel__header'>
                  <h2>{{localize 'MY_RPG.SheetLabels.Attributes'}}</h2>
                  <span>{{localize 'MY_RPG.SheetHints.ClickToRoll'}}</span>
                </header>
                <div class='andromeda-ability-grid'>
                  {{#each system.abilities as |ability key|}}
                    <article class='andromeda-ability-card {{ability.rankClass}}' data-ability-key='{{key}}'>
                      <button
                        type='button'
                        class='andromeda-ability-roll rollable'
                        data-ability='{{key}}'
                        data-label='{{ability.label}}'
                      >
                        <span class='andromeda-ability-top'>
                          <span class='andromeda-ability-title'>{{ability.label}}</span>
                          <span class='andromeda-ability-code'>{{ability.code}}</span>
                        </span>
                        <span class='andromeda-ability-body'>
                          <strong class='ability-die-value {{ability.rankClass}}'>{{ability.dieLabel}}</strong>
                          <span class='andromeda-ability-summary'>{{ability.skillSummary}}</span>
                        </span>
                      </button>
                      <div class='ability-die-control'>
                        <button
                          type='button'
                          class='ability-step'
                          data-step='-1'
                          aria-label='{{localize "MY_RPG.AbilityDice.Decrease"}}'
                        >
                          <i class='fa-solid fa-minus'></i>
                        </button>
                        <input type='hidden' name='system.abilities.{{key}}.value' value='{{ability.value}}' />
                        <button
                          type='button'
                          class='ability-step'
                          data-step='1'
                          aria-label='{{localize "MY_RPG.AbilityDice.Increase"}}'
                        >
                          <i class='fa-solid fa-plus'></i>
                        </button>
                      </div>
                    </article>
                  {{/each}}
                </div>
              </section>

              <section class='andromeda-skills-panel andromeda-panel'>
                <header class='andromeda-panel__header'>
                  <h2>{{localize 'MY_RPG.SheetLabels.Skills'}}</h2>
                  <span>{{localize 'MY_RPG.SheetHints.ClickToRoll'}}</span>
                </header>
                <div class='skills-grid andromeda-skills-grid'>
                  {{#each skillColumns as |column|}}
                    <section class='skills-column andromeda-skill-column'>
                      <header class='skills-column-header'>
                        <span class='skills-column-title'>{{column.label}}</span>
                      </header>
                      {{#each column.skills as |skill|}}
                        <div class='skill skill-row andromeda-skill-row'>
                          <button
                            type='button'
                            class='skill-col skill-name rollable'
                            data-skill='{{skill.key}}'
                            data-label='{{skill.label}}'
                          >
                            {{skill.label}}
                          </button>
                          <div class='skill-col skill-value'>
                            <input
                              class='{{skill.rankClass}}'
                              type='number'
                              name='system.skills.{{skill.key}}.value'
                              value='{{skill.value}}'
                              step='1'
                              inputmode='numeric'
                              pattern='\d+'
                              min='0'
                            />
                          </div>
                        </div>
                      {{/each}}
                    </section>
                  {{/each}}
                </div>
              </section>
            </div>

            <aside class='andromeda-side-stack'>
              <section class='andromeda-panel'>
                <header class='andromeda-panel__header'>
                  <h2>{{localize 'MY_RPG.SheetLabels.Defenses'}}</h2>
                  <span>{{localize 'MY_RPG.SheetHints.ReadOnly'}}</span>
                </header>
                <div class='andromeda-defense-grid'>
                  <label class='andromeda-defense'>
                    <span>{{localize 'MY_RPG.Defenses.FortitudeLabel'}}</span>
                    <input
                      type='number'
                      name='system.defenses.physical'
                      value='{{system.defenses.physical}}'
                      step='1'
                      inputmode='numeric'
                      readonly
                      tabindex='-1'
                    />
                  </label>
                  <label class='andromeda-defense'>
                    <span>{{localize 'MY_RPG.Defenses.ControlLabel'}}</span>
                    <input
                      type='number'
                      name='system.defenses.azure'
                      value='{{system.defenses.azure}}'
                      step='1'
                      inputmode='numeric'
                      readonly
                      tabindex='-1'
                    />
                  </label>
                  <label class='andromeda-defense'>
                    <span>{{localize 'MY_RPG.Defenses.WillLabel'}}</span>
                    <input
                      type='number'
                      name='system.defenses.mental'
                      value='{{system.defenses.mental}}'
                      step='1'
                      inputmode='numeric'
                      readonly
                      tabindex='-1'
                    />
                  </label>
                </div>
              </section>

              <section class='andromeda-temp-panel andromeda-panel'>
                <header class='andromeda-panel__header'>
                  <h2>{{localize 'MY_RPG.TempBonus.Label'}}</h2>
                  <span>{{localize 'MY_RPG.SheetHints.Editable'}}</span>
                </header>
                <div class='temp-bonus-grid'>
                  <label class='temp-bonus-field'>
                    <span>{{localize 'MY_RPG.TempStress.Label'}}</span>
                    <input type='number' name='system.temphealth' value='{{system.temphealth}}' />
                  </label>
                  <label class='temp-bonus-field'>
                    <span>{{localize 'MY_RPG.Temp.BonusFortitudeLabel'}}</span>
                    <input type='number' name='system.tempphys' value='{{system.tempphys}}' />
                  </label>
                  <label class='temp-bonus-field'>
                    <span>{{localize 'MY_RPG.Temp.BonusControlLabel'}}</span>
                    <input type='number' name='system.tempazure' value='{{system.tempazure}}' />
                  </label>
                  <label class='temp-bonus-field'>
                    <span>{{localize 'MY_RPG.Temp.BonusWillLabel'}}</span>
                    <input type='number' name='system.tempmental' value='{{system.tempmental}}' />
                  </label>
                  <label class='temp-bonus-field'>
                    <span>{{localize 'MY_RPG.TempSpeed.Label'}}</span>
                    <input type='number' name='system.tempspeed' value='{{system.tempspeed}}' />
                  </label>
                </div>
              </section>
            </aside>
          </section>
        </div>

        {{#each itemTabs as |tab|}}
          <div class='tab {{tab.key}} andromeda-item-tab' data-group='primary' data-tab='{{tab.key}}'>
            <section class='item-groups' data-groups='{{tab.key}}'>
              {{#each tab.groups as |group|}}
                {{> "systems/project-andromeda/templates/actor/partials/item-group-section.hbs" group=group}}
              {{/each}}
            </section>

            {{#if tab.isInventory}}
              <section class='andromeda-panel andromeda-resources-panel'>
                <header class='andromeda-panel__header'>
                  <h2>{{localize 'MY_RPG.Resources.Title'}}</h2>
                </header>
                <div class='andromeda-resources-grid'>
                  <label class='andromeda-field'>
                    <span>{{localize 'MY_RPG.Resources.SuppliesLabel'}}</span>
                    <input
                      type='number'
                      name='system.supplies'
                      value='{{tab.supplies}}'
                      step='1'
                      inputmode='numeric'
                    />
                  </label>
                  <label class='andromeda-field'>
                    <span>{{localize 'MY_RPG.Resources.MoneyLabel'}}</span>
                    <input
                      type='number'
                      name='system.money'
                      value='{{tab.money}}'
                      step='1'
                      inputmode='numeric'
                    />
                  </label>
                </div>
              </section>
            {{/if}}
          </div>
        {{/each}}

        {{#if isPlayerCharacter}}
          <div class='tab personality andromeda-personality-tab' data-group='primary' data-tab='personality'>
            <section class='andromeda-panel personality-sheet-box'>
              <header class='andromeda-panel__header'>
                <h2>{{localize 'MY_RPG.SheetLabels.Personality'}}</h2>
              </header>
              <div class='personality-grid'>
                <label class='form-group'>
                  <span>{{localize 'MY_RPG.Personality.Archetype'}}</span>
                  <textarea
                    class='auto-resize-textarea'
                    name='system.biography.archetype'
                    rows='2'
                  >{{system.biography.archetype}}</textarea>
                </label>
                <label class='form-group personality-field personality-field--full'>
                  <span>{{localize 'MY_RPG.Personality.Appearance'}}</span>
                  <textarea
                    class='auto-resize-textarea'
                    name='system.biography.appearance'
                    rows='2'
                  >{{system.biography.appearance}}</textarea>
                </label>
              </div>
            </section>

            <section class='item-groups personality-item-groups' data-groups='personality'>
              {{#if personalityValueGroup}}
                {{> "systems/project-andromeda/templates/actor/partials/item-group-section.hbs" group=personalityValueGroup}}
              {{/if}}
            </section>
          </div>
        {{/if}}
      </section>
    </div>
  </div>
</form>
