<form class="{{cssClass}} project-andromeda item-sheet cartridge-sheet" autocomplete="off">
  <header class="sheet-header item-header">
    <div class="item-image">
      <img
        src="{{item.img}}"
        data-edit="img"
        alt="{{item.name}}"
        title="{{item.name}}"
      />
    </div>
    <div class="item-details">
      <h1 class="sheet-title">
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="{{localize 'MY_RPG.Inventory.Name'}}"
          {{#unless editable}}disabled{{/unless}}
        />
      </h1>
      <div class="item-meta-grid">
        <div class="item-field">
          <label>{{localize 'MY_RPG.AbilityConfig.Rank'}}</label>
          <select name="system.rank" {{#unless editable}}disabled{{/unless}}>
            {{#each rankOptions}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>
  </header>

  <section class="sheet-body">
    <div class="item-section">
      <div class="item-fields-grid">
        <div class="item-field">
          <label>{{localize 'MY_RPG.AbilityConfig.Skill'}}</label>
          <select name="system.skill" {{#unless editable}}disabled{{/unless}}>
            {{#each skillOptions}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="item-field">
          <label>{{localize 'MY_RPG.AbilityConfig.SkillBonus'}}</label>
          <input
            type="number"
            name="system.skillBonus"
            value="{{system.skillBonus}}"
            {{#unless editable}}disabled{{/unless}}
          />
        </div>
      </div>
    </div>
    {{#if metadataFields.length}}
      <div class="item-section">
        <div class="item-meta-grid">
          {{#each metadataFields as |field|}}
            <div class="item-field{{#if field.isCheckbox}} item-field--checkbox{{/if}}">
              {{#if field.isCheckbox}}
                <label class="checkbox-label">
                  <input
                    type="checkbox"
                    name="system.{{field.path}}"
                    data-dtype="Boolean"
                    {{#if field.checked}}checked{{/if}}
                    {{#unless ../editable}}disabled{{/unless}}
                  />
                  <span>{{localize field.labelKey}}</span>
                </label>
              {{else}}
                <label>{{localize field.labelKey}}</label>
                {{#if field.hasOptions}}
                  <select name="system.{{field.path}}" {{#unless ../editable}}disabled{{/unless}}>
                    {{#each field.options as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>
                        {{option.label}}
                      </option>
                    {{/each}}
                  </select>
                {{else}}
                  <input
                    type="{{field.inputType}}"
                    name="system.{{field.path}}"
                    value="{{field.value}}"
                    {{#if field.hasMin}}min="{{field.min}}"{{/if}}
                    {{#unless ../editable}}disabled{{/unless}}
                  />
                {{/if}}
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}
    <div class="item-section rich-text-field">
      <label>{{localize 'MY_RPG.Inventory.Description'}}</label>
      <textarea
        name="system.description"
        class="description-input"
        data-description-editor
        spellcheck="false"
        rows="6"
        {{#unless editable}}disabled{{/unless}}
      >{{{system.description}}}</textarea>
    </div>
  </section>
</form>
