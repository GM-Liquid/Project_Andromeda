{
  "name": "project-andromeda",
  "version": "0.3.10",
  "private": true,
  "description": "Foundry VTT system and public rulebook tooling for Project Andromeda.",
  "scripts": {
    "build:pack": "node tools/build-pack.mjs",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:catalogs": "node tools/format-catalogs.mjs",
    "test": "npm run test:foundry",
    "test:foundry": "node --test \"module/**/*.test.mjs\" \"data/gear/tests/**/*.test.mjs\"",
    "test:quartz": "npm --prefix .quartz-site test",
    "check:quartz": "npm --prefix .quartz-site run check",
    "check:all": "npm run lint && npm run test:foundry && npm run check:quartz && npm run test:quartz"
  },
  "keywords": [],
  "author": "",
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "classic-level": "^3.0.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3"
  }
}
